{
  "name": "memocast",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vitepress dev wiki --host 0.0.0.0",
    "generate:graph": "node tools/knowledgeGraph.mjs",
    "generate:charts": "node tools/datasetCharts.mjs .",
    "generate:home": "node tools/homeDashboard.mjs .",
    "audit:citations": "node tools/citationAudit.mjs .",
    "build": "npm run generate:graph && npm run generate:charts && npm run audit:citations && npm run generate:home && vitepress build wiki",
    "preview": "vitepress preview wiki --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "latest",
    "vitepress": "latest",
    "vitest": "latest",
    "vue": "latest"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "vue-chartjs": "^5.3.3"
  }
}
